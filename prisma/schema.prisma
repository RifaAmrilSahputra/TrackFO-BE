generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  roles     UserRole[]
  teknisi   DataTeknisi?
}

model Role {
  id        Int    @id @default(autoincrement())
  nama_role String @unique

  users UserRole[]
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model DataTeknisi {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  noHp       String
  areaKerja  String
  alamat     String?

  latitude   Float?
  longitude  Float?
  lastSeen   DateTime?   // untuk cek aktif/tidak
  status     String  @default("available") // available, busy, off

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  trackings   Tracking[]
  laporan     Laporan[]
}

model Gangguan {
  id          Int      @id @default(autoincrement())
  judul       String
  deskripsi   String
  latitude    Float
  longitude   Float
  alamat      String

  status      String   @default("open") // open, assigned, on_progress, done
  priority    String?  // low, medium, high
  deadline    DateTime?

  createdAt   DateTime @default(now())

  assignments Assignment[]
  laporan     Laporan[]
}

model Assignment {
  id          Int      @id @default(autoincrement())
  gangguanId  Int
  teknisiId   Int

  isLeader    Boolean  @default(false)
  status      String   @default("assigned") // assigned, on_the_way, working, done

  assignedAt  DateTime @default(now())
  assignedBy  Int?     // admin yang assign
  method      String?  // manual / auto

  gangguan Gangguan @relation(fields: [gangguanId], references: [id], onDelete: Cascade)
  teknisi  DataTeknisi @relation(fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([gangguanId])
  @@index([teknisiId])
}

model Tracking {
  id          Int      @id @default(autoincrement())
  teknisiId   Int
  latitude    Float
  longitude   Float
  recordedAt  DateTime @default(now())

  teknisi DataTeknisi @relation(fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([teknisiId])
}

model Laporan {
  id           Int      @id @default(autoincrement())
  gangguanId   Int
  teknisiId    Int // leader yang submit

  catatan      String
  foto         String?
  waktuSelesai DateTime @default(now())

  gangguan Gangguan @relation(fields: [gangguanId], references: [id], onDelete: Cascade)
  teknisi  DataTeknisi @relation(fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([gangguanId])
}