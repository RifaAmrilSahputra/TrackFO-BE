{
  "name": "trackfo-be",
  "version": "1.0.0",
  "description": "Backend untuk aplikasi TrackFO",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules npx jest --watchAll",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules npx jest --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed/seed.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "rest-api",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(supertest|@prisma)/)"
    ],
    "forceExit": true,
    "detectOpenHandles": true,
    "testTimeout": 30000
  }
}
