{
  "name": "trackfo-be",
  "version": "1.0.0",
  "description": "Backend untuk aplikasi TrackFO",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules npx jest test/unit --runInBand",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules npx jest test/integration --runInBand",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules npx jest test/e2e --runInBand",
    "test:auth": "NODE_OPTIONS=--experimental-vm-modules npx jest test/integration/auth.test.js --runInBand",
    "test:user": "NODE_OPTIONS=--experimental-vm-modules npx jest test/integration/user.test.js --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules npx jest --watchAll",
    "test:watch:unit": "NODE_OPTIONS=--experimental-vm-modules npx jest test/unit --watchAll",
    "test:watch:integration": "NODE_OPTIONS=--experimental-vm-modules npx jest test/integration --watchAll",
    "test:watch:e2e": "NODE_OPTIONS=--experimental-vm-modules npx jest test/e2e --watchAll",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules npx jest --coverage",
    "test:coverage:unit": "NODE_OPTIONS=--experimental-vm-modules npx jest test/unit --coverage --runInBand",
    "test:coverage:integration": "NODE_OPTIONS=--experimental-vm-modules npx jest test/integration --coverage --runInBand",
    "test:coverage:e2e": "NODE_OPTIONS=--experimental-vm-modules npx jest test/e2e --coverage --runInBand"
  },
  "prisma": {
    "seed": "node prisma/seed/seed.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "rest-api",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/test/helpers/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(supertest|@prisma)/)"
    ],
    "forceExit": true,
    "detectOpenHandles": true,
    "testTimeout": 30000
  }
}
